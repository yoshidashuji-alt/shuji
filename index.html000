// ============================================================
// DentalCase アプリ本体ロジック
// ============================================================

const APP_STATE = {
  role: null,          // "student" | "teacher"
  userName: null,
  currentCase: null,   // CASES[i]
  chatHistory: [],     // [{role:"patient"|"student", text}]
  apiBusy: false,
};

const STORAGE_PREFIX = "dentalcase";

// ------------------------------------------------------------
// Storage helpers (shared=true なので教員が学生の記録を見られる)
// ------------------------------------------------------------
// storageキーは空白・スラッシュ・引用符を含められないため、
// 学生名や症例IDをそのままキーに使うと（特に日本語氏名にスペースが
// 含まれる場合）保存に失敗する。英数字のみの安全な文字列に変換する。
function toSafeKeyPart(str) {
  let hash = 0;
  const s = String(str);
  for (let i = 0; i < s.length; i++) {
    hash = (hash * 31 + s.charCodeAt(i)) >>> 0;
  }
  return "h" + hash.toString(36);
}

async function saveSessionRecord(record) {
  const safeName = toSafeKeyPart(record.studentName);
  const safeCaseId = toSafeKeyPart(record.caseId);
  const key = `${STORAGE_PREFIX}:session:${safeName}:${safeCaseId}:${record.timestamp}`;
  const valueStr = JSON.stringify(record);

  // storageバックエンドの一時的なエラーに備えて、1回だけ自動リトライする
  for (let attempt = 1; attempt <= 2; attempt++) {
    try {
      const result = await window.storage.set(key, valueStr, true);
      if (result) return; // 成功
      console.error(`保存に失敗しました（resultがnull, attempt ${attempt}）`);
    } catch (e) {
      console.error(`保存に失敗しました（attempt ${attempt}）`, e);
      if (attempt === 2) {
        // 2回試しても失敗した場合のみ知らせる。
        // 保存失敗はこの学習履歴の記録のみに影響し、
        // 学生に表示済みのAI評価結果には影響しないことを伝える。
        alert("学習履歴の保存に失敗しました（教員側の履歴に記録されない可能性があります）。評価結果はこのまま確認いただけます。\n詳細：" + e.message);
      } else {
        await new Promise(r => setTimeout(r, 800)); // 少し待ってリトライ
      }
    }
  }
}

async function listAllSessionRecords() {
  try {
    const res = await window.storage.list(`${STORAGE_PREFIX}:session:`, true);
    if (!res || !res.keys || res.keys.length === 0) return [];
    const records = [];
    for (const k of res.keys) {
      try {
        const got = await window.storage.get(k, true);
        if (got && got.value) records.push(JSON.parse(got.value));
      } catch (e) { /* skip broken entries */ }
    }
    return records;
  } catch (e) {
    console.error("一覧取得に失敗しました", e);
    return [];
  }
}

// ------------------------------------------------------------
// Claude API 呼び出し
// ------------------------------------------------------------
async function callClaude(systemPrompt, messages, maxTokens = 600) {
  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-6",
      max_tokens: maxTokens,
      system: systemPrompt,
      messages: messages,
    }),
  });
  if (!response.ok) {
    throw new Error("API呼び出しに失敗しました: " + response.status);
  }
  const data = await response.json();
  const textBlock = (data.content || []).find(b => b.type === "text");
  return textBlock ? textBlock.text : "";
}

// テキスト中からJSONオブジェクトを抜き出してパースする関数。
// コードブロック記号や前後の説明文が混じっていても、
// 最初の { から対応する } までを抜き出して解析する。
function extractJsonFromText(text) {
  const cleaned = text.replace(/```json|```/g, "");
  const start = cleaned.indexOf("{");
  if (start === -1) return null;
  let depth = 0;
  for (let i = start; i < cleaned.length; i++) {
    if (cleaned[i] === "{") depth++;
    if (cleaned[i] === "}") {
      depth--;
      if (depth === 0) {
        const jsonStr = cleaned.slice(start, i + 1);
        try {
          return JSON.parse(jsonStr);
        } catch (e) {
          console.error("JSON抜き出し後のパースに失敗:", e);
          return null;
        }
      }
    }
  }
  return null;
}

// AIの評価をJSON形式のテキストで受け取り、パースして返す。
async function callClaudePlainJson(systemPrompt, messages, maxTokens = 2000) {
  const text = await callClaude(systemPrompt, messages, maxTokens);
  const extracted = extractJsonFromText(text);
  if (!extracted) {
    console.error("AIの応答からJSONを読み取れませんでした:", text);
    throw new Error("AIの応答からJSONを読み取れませんでした。応答内容：" + text.slice(0, 300));
  }
  return extracted;
}

// ============================================================
// 画面遷移
// ============================================================
function showScreen(id) {
  document.querySelectorAll(".screen").forEach(s => s.classList.remove("active"));
  document.getElementById(id).classList.add("active");
}

// ============================================================
// ログイン
// ============================================================
function initLogin() {
  const roleStudentBtn = document.getElementById("role-student");
  const roleTeacherBtn = document.getElementById("role-teacher");
  const labelName = document.getElementById("label-name");

  roleStudentBtn.addEventListener("click", () => {
    roleStudentBtn.classList.add("active");
    roleTeacherBtn.classList.remove("active");
    labelName.textContent = "氏名 / 学籍番号";
    APP_STATE.role = "student";
  });
  roleTeacherBtn.addEventListener("click", () => {
    roleTeacherBtn.classList.add("active");
    roleStudentBtn.classList.remove("active");
    labelName.textContent = "氏名（教員）";
    APP_STATE.role = "teacher";
  });
  APP_STATE.role = "student";

  document.getElementById("btn-login").addEventListener("click", () => {
    const name = document.getElementById("login-name").value.trim();
    APP_STATE.userName = name || (APP_STATE.role === "student" ? "ゲスト学生" : "ゲスト教員");

    if (APP_STATE.role === "student") {
      document.getElementById("student-welcome").textContent = `${APP_STATE.userName} さん`;
      renderCaseList();
      showScreen("screen-case-list");
    } else {
      document.getElementById("teacher-welcome").textContent = `${APP_STATE.userName} 先生`;
      renderTeacherDashboard();
      showScreen("screen-teacher-dash");
    }
  });

  document.getElementById("btn-logout-1").addEventListener("click", logout);
  document.getElementById("btn-logout-2").addEventListener("click", logout);
}

function logout() {
  APP_STATE.role = null;
  APP_STATE.userName = null;
  APP_STATE.currentCase = null;
  APP_STATE.chatHistory = [];
  document.getElementById("login-name").value = "";
  document.getElementById("login-pass").value = "";
  showScreen("screen-login");
}

// ============================================================
// 学生：症例一覧
// ============================================================
function renderCaseList() {
  const scroll = document.getElementById("case-list-scroll");
  // keep the section label, rebuild cards
  scroll.innerHTML = `<div class="section-label">本日の症例</div>`;
  CASES.forEach(c => {
    const card = document.createElement("div");
    card.className = "case-card";
    card.innerHTML = `
      <div class="top-row">
        <div class="case-title">${c.title}</div>
        <div class="case-id">${c.id}</div>
      </div>
      <div class="case-desc">${c.shortDesc}</div>
      <div class="meta-row">
        ${c.tags.map(t => `<span class="tag">${t}</span>`).join("")}
      </div>
    `;
    card.addEventListener("click", () => openCase(c));
    scroll.appendChild(card);
  });
}

// ============================================================
// 学生：症例ワークスペース
// ============================================================
function openCase(caseObj) {
  APP_STATE.currentCase = caseObj;
  APP_STATE.chatHistory = [];

  // 前の症例で進行中だった音声認識・読み上げがあれば停止する
  stopListening();
  if (VOICE_STATE.recognition) VOICE_STATE.recognition.abort();
  if ("speechSynthesis" in window) window.speechSynthesis.cancel();

  document.getElementById("ws-case-title").textContent = `${caseObj.id}　${caseObj.title}`;
  document.getElementById("ws-case-sub").textContent = caseObj.patientName;

  // brief box
  document.getElementById("brief-box").innerHTML = `
    <div class="patient-name">${caseObj.patientName}</div>
    <div class="patient-meta">来院理由を問診で確認しましょう</div>
    <div class="chief-complaint">主訴：「${caseObj.chiefComplaint}」</div>
  `;

  // reset chat log with opening line from patient
  const chatLog = document.getElementById("chat-log");
  chatLog.innerHTML = "";
  appendSystemNote(`${caseObj.patientName} さんが診察室に入ってきました。問診を開始してください。`);
  appendPatientMessage(`こんにちは、よろしくお願いします。今日は…${caseObj.chiefComplaint}`);
  APP_STATE.chatHistory.push({ role: "patient", text: `こんにちは、よろしくお願いします。今日は…${caseObj.chiefComplaint}` });

  // quick chips
  renderQuickChips(caseObj);

  // images tab
  renderImageTab(caseObj);

  // reset diagnosis form
  document.getElementById("diag-differential").value = "";
  document.getElementById("diag-final").value = "";
  document.getElementById("diag-rationale").value = "";
  document.getElementById("diag-plan").value = "";

  // reset to interview tab
  switchTab("interview");
  showScreen("screen-case-workspace");
}

function renderQuickChips(caseObj) {
  const quickRow = document.getElementById("quick-row");
  const chips = [
    "いつから痛みますか？",
    "どのような痛みですか？",
    "冷たいもの・温かいもので痛みは変わりますか？",
    "これまでに歯の治療を受けたことはありますか？",
  ];
  quickRow.innerHTML = "";
  chips.forEach(c => {
    const chip = document.createElement("div");
    chip.className = "quick-chip";
    chip.textContent = c;
    chip.addEventListener("click", () => {
      document.getElementById("chat-input").value = c;
      sendChatMessage();
    });
    quickRow.appendChild(chip);
  });
}

function renderImageTab(caseObj) {
  const grid = document.getElementById("image-grid");
  grid.innerHTML = "";
  caseObj.images.forEach(img => {
    const card = document.createElement("div");
    card.className = "image-card";
    card.innerHTML = `
      <div class="img-wrap">${CASE_IMAGES_SVG[img.svgKey]}</div>
      <div class="img-caption"><b>${img.title}</b><br>${img.caption}</div>
    `;
    grid.appendChild(card);
  });
  const note = document.createElement("div");
  note.className = "lock-note";
  note.textContent = "※ これらは模式図です。実際の臨床所見の特徴を再現したサンプル画像として参照してください。";
  grid.parentElement.insertBefore(note, grid);
}

// ---- tabs ----
function switchTab(tabName) {
  document.querySelectorAll(".tab-btn").forEach(b => b.classList.toggle("active", b.dataset.tab === tabName));
  document.querySelectorAll(".bn-tab").forEach(b => b.classList.toggle("active", b.dataset.tab === tabName));
  document.querySelectorAll(".tab-panel").forEach(p => p.classList.remove("active"));
  document.getElementById(`panel-${tabName}`).classList.add("active");
}

function initTabs() {
  document.querySelectorAll(".tab-btn, .bn-tab").forEach(btn => {
    btn.addEventListener("click", () => switchTab(btn.dataset.tab));
  });
}

// ---- chat rendering ----
function appendPatientMessage(text) {
  const chatLog = document.getElementById("chat-log");

  const wrap = document.createElement("div");
  wrap.className = "msg-with-audio";

  const bubble = document.createElement("div");
  bubble.className = "msg patient";
  bubble.textContent = text;

  const speakBtn = document.createElement("button");
  speakBtn.className = "speak-btn";
  speakBtn.title = "読み上げる";
  speakBtn.textContent = "🔊";
  speakBtn.addEventListener("click", () => speakText(text, speakBtn));

  wrap.appendChild(bubble);
  wrap.appendChild(speakBtn);
  chatLog.appendChild(wrap);
  chatLog.scrollTop = chatLog.scrollHeight;

  // 音声モードがONの場合は自動で読み上げる
  if (isVoiceModeOn()) {
    speakText(text, speakBtn);
  }
}
function appendStudentMessage(text) {
  const chatLog = document.getElementById("chat-log");
  const div = document.createElement("div");
  div.className = "msg student";
  div.textContent = text;
  chatLog.appendChild(div);
  chatLog.scrollTop = chatLog.scrollHeight;
}
function appendSystemNote(text) {
  const chatLog = document.getElementById("chat-log");
  const div = document.createElement("div");
  div.className = "msg system-note";
  div.textContent = text;
  chatLog.appendChild(div);
  chatLog.scrollTop = chatLog.scrollHeight;
}
function showTypingIndicator() {
  const chatLog = document.getElementById("chat-log");
  const div = document.createElement("div");
  div.className = "typing-dots";
  div.id = "typing-indicator";
  div.innerHTML = "<span></span><span></span><span></span>";
  chatLog.appendChild(div);
  chatLog.scrollTop = chatLog.scrollHeight;
}
function hideTypingIndicator() {
  const el = document.getElementById("typing-indicator");
  if (el) el.remove();
}

// ============================================================
// 音声モード（音声認識・音声合成）
// ============================================================
const VOICE_STATE = {
  recognition: null,
  isListening: false,
  speechSupported: false,
};

function isVoiceModeOn() {
  const toggle = document.getElementById("voice-mode-toggle");
  return toggle && toggle.checked;
}

// 音声合成（テキスト読み上げ）。日本語ボイスを優先して選択する。
function speakText(text, btnEl) {
  if (!("speechSynthesis" in window)) return;
  window.speechSynthesis.cancel(); // 前の発話があれば止めて新しいものを再生

  const utter = new SpeechSynthesisUtterance(text);
  utter.lang = "ja-JP";
  const voices = window.speechSynthesis.getVoices();
  const jaVoice = voices.find(v => v.lang === "ja-JP") || voices.find(v => v.lang && v.lang.startsWith("ja"));
  if (jaVoice) utter.voice = jaVoice;
  utter.rate = 1.0;

  if (btnEl) {
    btnEl.classList.add("speaking");
    utter.onend = () => btnEl.classList.remove("speaking");
    utter.onerror = () => btnEl.classList.remove("speaking");
  }
  window.speechSynthesis.speak(utter);
}

// 音声認識（マイク入力 → テキスト化）の初期化。
// ブラウザが対応していない場合は静かにフォールバックし、
// マイクボタンを使えないようにする（テキスト入力は常に使える）。
function initVoiceRecognition() {
  const SpeechRecognitionImpl = window.SpeechRecognition || window.webkitSpeechRecognition;
  const micBtn = document.getElementById("btn-mic");

  if (!SpeechRecognitionImpl) {
    VOICE_STATE.speechSupported = false;
    micBtn.disabled = true;
    micBtn.title = "このブラウザは音声入力に対応していません（テキスト入力をご利用ください）";
    micBtn.style.opacity = "0.4";
    return;
  }

  VOICE_STATE.speechSupported = true;
  const recognition = new SpeechRecognitionImpl();
  recognition.lang = "ja-JP";
  recognition.interimResults = false;
  recognition.maxAlternatives = 1;

  recognition.onresult = (event) => {
    const transcript = event.results[0][0].transcript;
    const input = document.getElementById("chat-input");
    input.value = transcript;
    // 音声モードでは、認識結果を自動送信する
    sendChatMessage();
  };
  recognition.onerror = (event) => {
    console.error("音声認識エラー:", event.error);
    stopListening();

    const errorMessages = {
      "not-allowed": "マイクの使用が許可されていません。ブラウザの設定でマイクへのアクセスを許可してください。",
      "service-not-allowed": "マイクの使用が許可されていません。ブラウザの設定でマイクへのアクセスを許可してください。",
      "no-speech": "音声が検出されませんでした。もう一度お試しください。",
      "audio-capture": "マイクが見つかりません。マイクが接続されているか確認してください。",
      "network": "音声認識サービスに接続できませんでした。通信環境を確認するか、テキスト入力をご利用ください。",
      "aborted": null, // ユーザー操作による中断は静かに無視する
    };
    const message = Object.prototype.hasOwnProperty.call(errorMessages, event.error)
      ? errorMessages[event.error]
      : `音声認識でエラーが発生しました（${event.error}）。テキスト入力をご利用ください。`;
    if (message) alert(message);
  };
  recognition.onend = () => {
    stopListening();
  };

  VOICE_STATE.recognition = recognition;
}

function startListening() {
  if (!VOICE_STATE.speechSupported || VOICE_STATE.isListening) return;
  try {
    VOICE_STATE.recognition.start();
    VOICE_STATE.isListening = true;
    document.getElementById("btn-mic").classList.add("listening");
  } catch (e) {
    console.error("音声認識の開始に失敗しました", e);
    alert("音声認識を開始できませんでした。\n詳細：" + e.message);
  }
}
function stopListening() {
  VOICE_STATE.isListening = false;
  const micBtn = document.getElementById("btn-mic");
  if (micBtn) micBtn.classList.remove("listening");
}

function initVoiceModeToggle() {
  const toggle = document.getElementById("voice-mode-toggle");
  const workspace = document.getElementById("screen-case-workspace");
  toggle.addEventListener("change", () => {
    workspace.classList.toggle("voice-mode-on", toggle.checked);
    if (toggle.checked) {
      // 音声合成エンジンの音声リストを先読みしておく（初回は空配列になりやすいため）
      if ("speechSynthesis" in window) window.speechSynthesis.getVoices();
    } else {
      stopListening();
      if (VOICE_STATE.recognition) VOICE_STATE.recognition.abort();
      window.speechSynthesis && window.speechSynthesis.cancel();
    }
  });

  document.getElementById("btn-mic").addEventListener("click", () => {
    if (VOICE_STATE.isListening) {
      VOICE_STATE.recognition.stop();
    } else {
      startListening();
    }
  });
}

// ---- sending a chat message ----
async function sendChatMessage() {
  if (APP_STATE.apiBusy) return;
  const input = document.getElementById("chat-input");
  const text = input.value.trim();
  if (!text) return;

  appendStudentMessage(text);
  APP_STATE.chatHistory.push({ role: "student", text });
  input.value = "";
  input.style.height = "auto";

  const sendBtn = document.getElementById("btn-send");
  sendBtn.disabled = true;
  APP_STATE.apiBusy = true;
  showTypingIndicator();

  try {
    const apiMessages = APP_STATE.chatHistory.map(m => ({
      role: m.role === "student" ? "user" : "assistant",
      content: m.text,
    }));
    const reply = await callClaude(APP_STATE.currentCase.patientSystemPrompt, apiMessages, 300);
    hideTypingIndicator();
    appendPatientMessage(reply);
    APP_STATE.chatHistory.push({ role: "patient", text: reply });
  } catch (e) {
    hideTypingIndicator();
    appendSystemNote("通信エラーが発生しました。もう一度お試しください。");
    console.error(e);
  } finally {
    sendBtn.disabled = false;
    APP_STATE.apiBusy = false;
  }
}

function initChatInput() {
  const input = document.getElementById("chat-input");
  const sendBtn = document.getElementById("btn-send");
  sendBtn.addEventListener("click", sendChatMessage);
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendChatMessage();
    }
  });
  input.addEventListener("input", () => {
    input.style.height = "auto";
    input.style.height = Math.min(input.scrollHeight, 90) + "px";
  });
}

// ============================================================
// 診断提出 → AI評価
// ============================================================
function initDiagnosisSubmit() {
  document.getElementById("btn-submit-diag").addEventListener("click", submitDiagnosis);
  document.getElementById("btn-back-to-list").addEventListener("click", () => {
    renderCaseList();
    showScreen("screen-case-list");
  });
}

async function submitDiagnosis() {
  const differential = document.getElementById("diag-differential").value.trim();
  const final = document.getElementById("diag-final").value.trim();
  const rationale = document.getElementById("diag-rationale").value.trim();
  const plan = document.getElementById("diag-plan").value.trim();

  if (!final || !rationale || !plan) {
    alert("②確定診断、③診断の根拠、④治療方針は必須項目です。入力してください。");
    return;
  }

  const submitBtn = document.getElementById("btn-submit-diag");
  submitBtn.disabled = true;
  submitBtn.innerHTML = `<span class="loading-spinner"></span> AIが評価中…`;

  const caseObj = APP_STATE.currentCase;
  const chatTranscript = APP_STATE.chatHistory
    .map(m => `${m.role === "student" ? "学生" : "患者"}：${m.text}`)
    .join("\n");

  const evalSystemPrompt = `あなたは歯学部の臨床推論トレーニングを評価する、経験豊富な歯科臨床教育者です。
学生が行った問診の記録と、学生が記入した診断・治療方針を、以下の「症例の正解情報」に基づいて評価してください。

【症例の正解情報】
正解診断：${caseObj.correctDiagnosis}
重要所見：
${caseObj.keyFindings.map(f => "- " + f).join("\n")}
理想的に確認すべき問診項目：
${caseObj.idealQuestions.map(q => "- " + q).join("\n")}

評価結果は submit_evaluation ツールを使って送信してください。各テキスト項目は改行を含めず、1行の自然な日本語の文章として書いてください。`;

  const userPrompt = `【問診の記録】
${chatTranscript || "（問診は行われませんでした）"}

【学生が記入した内容】
鑑別診断：${differential || "（記入なし）"}
確定診断：${final}
診断の根拠：${rationale}
治療方針：${plan}`;

  // プレーンテキストJSON方式用のプロンプト
  const plainJsonInstruction = `

【出力形式】
必ず以下のJSON形式のみで出力してください。説明文やMarkdownのコードブロック記号は一切付けないでください。各文字列の値には改行を含めず、1行で書いてください。
{
  "score": 0から100の整数,
  "summary": "1〜2文の総評",
  "good_points": ["評価できる点1", "評価できる点2"],
  "missed_points": ["見落としていた点1", "見落としていた点2"],
  "diagnosis_feedback": "診断・治療方針への詳しいフィードバック",
  "advice": "次に活かすアドバイス"
}`;

  try {
    // この実行環境ではtool use（構造化出力）がテキスト内に
    // <function_calls>記法として出力されてしまい安定しないため、
    // プレーンテキストJSON方式のみを使用する。
    const evalResult = await callClaudePlainJson(
      evalSystemPrompt + plainJsonInstruction,
      [{ role: "user", content: userPrompt }],
      2000
    );

    // persist
    const record = {
      studentName: APP_STATE.userName,
      caseId: caseObj.id,
      caseTitle: caseObj.title,
      timestamp: Date.now(),
      timestampReadable: new Date().toLocaleString("ja-JP"),
      chatHistory: APP_STATE.chatHistory,
      studentInput: { differential, final, rationale, plan },
      evalResult,
    };
    await saveSessionRecord(record);

    renderEvaluation(evalResult, caseObj);
    showScreen("screen-evaluation");
  } catch (e) {
    console.error(e);
    alert("評価の取得に失敗しました。通信状態を確認し、もう一度お試しください。\n詳細：" + e.message);
  } finally {
    submitBtn.disabled = false;
    submitBtn.textContent = "AIによる評価を受ける";
  }
}

function renderEvaluation(evalResult, caseObj) {
  document.getElementById("eval-case-sub").textContent = `${caseObj.id}　${caseObj.title}`;
  const wrap = document.getElementById("eval-wrap");

  const goodHtml = (evalResult.good_points || []).map(p => `<li>${escapeHtml(p)}</li>`).join("");
  const missedHtml = (evalResult.missed_points || []).map(p => `<li>${escapeHtml(p)}</li>`).join("");

  wrap.innerHTML = `
    <div class="score-hero">
      <div class="score-num">${evalResult.score ?? "--"}</div>
      <div class="score-label">SCORE / 100</div>
    </div>
    <div class="eval-section">
      <h4>📌 総評</h4>
      <p>${escapeHtml(evalResult.summary || "")}</p>
    </div>
    <div class="eval-section good">
      <h4>✓ 評価できる点</h4>
      <ul>${goodHtml || "<li>特になし</li>"}</ul>
    </div>
    <div class="eval-section warn">
      <h4>△ 見落としていた点</h4>
      <ul>${missedHtml || "<li>特になし</li>"}</ul>
    </div>
    <div class="eval-section">
      <h4>🩺 診断・治療方針へのフィードバック</h4>
      <p>${escapeHtml(evalResult.diagnosis_feedback || "")}</p>
    </div>
    <div class="eval-section">
      <h4>💡 次に活かすアドバイス</h4>
      <p>${escapeHtml(evalResult.advice || "")}</p>
    </div>
    <button class="btn-secondary" id="btn-back-from-eval" style="margin-top:6px;">症例一覧に戻る</button>
  `;
  document.getElementById("btn-back-from-eval").addEventListener("click", () => {
    renderCaseList();
    showScreen("screen-case-list");
  });
}

function escapeHtml(str) {
  const div = document.createElement("div");
  div.textContent = str ?? "";
  return div.innerHTML;
}

function initEvalScreen() {
  document.getElementById("btn-eval-close").addEventListener("click", () => {
    renderCaseList();
    showScreen("screen-case-list");
  });
}

// ============================================================
// 教員：ダッシュボード
// ============================================================
async function renderTeacherDashboard() {
  const list = document.getElementById("student-list");
  list.innerHTML = `<div class="empty-state"><div class="e-icon">⏳</div><div class="e-title">読み込み中…</div></div>`;

  const records = await listAllSessionRecords();

  if (records.length === 0) {
    list.innerHTML = `
      <div class="empty-state">
        <div class="e-icon">📭</div>
        <div class="e-title">まだ学習記録がありません</div>
        <div class="e-desc">学生が症例に取り組み、AI評価を完了すると、ここに記録が表示されます。</div>
      </div>`;
    return;
  }

  // group by student
  const byStudent = {};
  records.forEach(r => {
    if (!byStudent[r.studentName]) byStudent[r.studentName] = [];
    byStudent[r.studentName].push(r);
  });

  list.innerHTML = "";
  Object.keys(byStudent).sort().forEach(name => {
    const recs = byStudent[name].sort((a, b) => b.timestamp - a.timestamp);
    const avg = Math.round(recs.reduce((sum, r) => sum + (r.evalResult.score || 0), 0) / recs.length);

    const row = document.createElement("div");
    row.className = "student-row";
    row.innerHTML = `
      <div class="top-row">
        <div>
          <div class="s-name">${escapeHtml(name)}</div>
          <div class="s-meta">取り組み症例数：${recs.length}件</div>
        </div>
        <div class="avg-pill">平均 ${avg}点</div>
      </div>
    `;
    row.addEventListener("click", () => openTeacherDetail(name, recs));
    list.appendChild(row);
  });
}

function openTeacherDetail(studentName, records) {
  document.getElementById("td-student-name").textContent = `${studentName} さん`;
  const scroll = document.getElementById("teacher-detail-scroll");
  scroll.innerHTML = `<div class="section-label">学習履歴（新しい順）</div>`;

  records.forEach((r, idx) => {
    const entry = document.createElement("div");
    entry.className = "log-entry";

    const chatHtml = (r.chatHistory || []).map(m =>
      `<div class="mini-chat-line"><b>${m.role === "student" ? "学生" : "患者"}：</b>${escapeHtml(m.text)}</div>`
    ).join("");

    entry.innerHTML = `
      <div class="log-head">
        <div>
          <div class="lt">${r.caseId}　${escapeHtml(r.caseTitle)}</div>
          <div class="ld">${r.timestampReadable} ・ スコア ${r.evalResult.score}点</div>
        </div>
        <div class="chevron">▶</div>
      </div>
      <div class="log-body">
        <div class="section-label" style="margin-top:10px;">問診ログ</div>
        ${chatHtml || "<p style='font-size:12.5px;color:var(--ink-soft);'>問診は行われませんでした。</p>"}

        <div class="section-label">学生の診断・治療方針</div>
        <div class="mini-chat-line"><b>鑑別診断：</b>${escapeHtml(r.studentInput.differential) || "（記入なし）"}</div>
        <div class="mini-chat-line"><b>確定診断：</b>${escapeHtml(r.studentInput.final)}</div>
        <div class="mini-chat-line"><b>根拠：</b>${escapeHtml(r.studentInput.rationale)}</div>
        <div class="mini-chat-line"><b>治療方針：</b>${escapeHtml(r.studentInput.plan)}</div>

        <div class="section-label">AI評価</div>
        <div class="mini-chat-line"><b>総評：</b>${escapeHtml(r.evalResult.summary)}</div>
        <div class="mini-chat-line"><b>フィードバック：</b>${escapeHtml(r.evalResult.diagnosis_feedback)}</div>
      </div>
    `;
    entry.querySelector(".log-head").addEventListener("click", () => {
      entry.classList.toggle("open");
    });
    scroll.appendChild(entry);
  });

  showScreen("screen-teacher-detail");
}

function initTeacherNav() {
  document.getElementById("btn-teacher-back").addEventListener("click", () => {
    renderTeacherDashboard();
    showScreen("screen-teacher-dash");
  });
}

// ============================================================
// 起動
// ============================================================
document.addEventListener("DOMContentLoaded", () => {
  initLogin();
  initTabs();
  initChatInput();
  initDiagnosisSubmit();
  initEvalScreen();
  initTeacherNav();
  initVoiceRecognition();
  initVoiceModeToggle();
});

</script>
</body>
</html>
